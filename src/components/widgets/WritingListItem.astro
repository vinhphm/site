---
import type { CollectionEntry } from 'astro:content'
import { formatDate } from '@/utils/date'
import { getDisplayDate } from '@/utils/writing'

type Props = {
  writing: CollectionEntry<'writings'>
}

const { writing } = Astro.props
const displayDate = getDisplayDate(writing)
---

<li>
  <a
    href={`/writing/${writing.id}`}
    transition:name={`writing-id-${writing.id}`}
  >
    <div class="post-item">
      <p class="title">{writing.data.title}</p>
      <div class="divider"></div>
      <p class="date post-date">{formatDate(displayDate)}</p>
    </div>
  </a>
</li>

<style>
  li {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  a {
    color: var(--text-primary);
    display: block;
    text-decoration: none;
    transition: opacity 0.15s ease-out;
  }

  .post-item {
    height: 2.75rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
  }

  .title {
    margin: 0;
    flex-shrink: 1;
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .divider {
    flex: 1 1 auto;
    min-width: 3rem;
    margin: 0 0.25rem;
    height: 0.5px;
    background-color: var(--border);
  }

  .post-date {
    margin: 0;
    color: var(--text-secondary);
    opacity: 0.75;
    letter-spacing: -0.08em;
    flex-shrink: 0;
    white-space: nowrap;
  }
</style>
