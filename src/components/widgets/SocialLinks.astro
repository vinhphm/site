---
import EmailLink from '@/components/ui/EmailLink.astro'
import config from '@/config'

const links = config.footer.navLinks
---

<p>{"Find me on "}{links.map((link, i) => {
  const isLast = i === links.length - 1
  const isSecondLast = i === links.length - 2
  const sep = isLast ? '.' : isSecondLast ? ' or ' : ', '
  if (link.text === 'email') return <EmailLink text={link.text} suffix={sep} />
  return <Fragment><a href={link.href} target="_blank" rel="noopener">{link.text}</a>{sep}</Fragment>
})}</p>
