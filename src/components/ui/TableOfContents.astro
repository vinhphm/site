---
type TOCItem = {
  level: number
  text: string
  id: string
}

type Props = {
  toc?: TOCItem[]
}

const { toc = [] } = Astro.props
---

<div class="toc-container" id="toc">
  <nav class="toc-nav">
    <ul class="toc-list" id="toc-list">
      <li class="toc-item toc-level-0">
        <a
          href="#"
          class="toc-link toc-title"
          title="Back to top"
          data-text="Back to top"
        >
          Back to top
        </a>
      </li>
      {
        toc.map((item) => (
          <li class={`toc-item toc-level-${item.level}`}>
            <a
              href={`#${item.id}`}
              class="toc-link"
              title={item.text}
              data-text={item.text}
            >
              {item.text}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</div>

<script is:inline>
  ;(function () {
    if (window.__tocController?.destroy) {
      window.__tocController.destroy()
    }

    var contentWidth = 35 // rem, matches Layout.astro max-w-[35rem]
    var centeredLayout = true
    var tocEnabled = true
    var activeOffset = 96

    var state = {
      container: null,
      linkList: [],
      headingList: [],
      titleLink: null,
      headingMap: new Map(),
      headingObserver: null,
      resizeTimeout: null,
      resetTimeout: null,
      activeLink: null,
      activeId: null,
      hasContent: false,
    }

    function initElements() {
      state.container = document.querySelector('.toc-container')
      if (!state.container) return false

      state.linkList = Array.from(document.querySelectorAll('.toc-link'))
      state.headingList = Array.from(
        document.querySelectorAll('h1, h2, h3')
      ).filter(function (heading, index, headings) {
        return !(index === 0 && headings[0].tagName === 'H1') && heading.id
      })
      state.titleLink = document.querySelector('.toc-link.toc-title')

      state.headingMap.clear()
      state.linkList.forEach(function (link) {
        var href = link.getAttribute('href')
        if (href && href.startsWith('#')) {
          state.headingMap.set(href.substring(1), link)
        }
      })

      return true
    }

    function checkContent() {
      if (!state.container) return
      var tocItems = state.linkList.filter(function (link) {
        return !link.classList.contains('toc-title')
      })
      state.hasContent = tocItems.length > 0
      if (!state.hasContent) {
        state.container.style.display = 'none'
      }
    }

    function adjustPosition() {
      if (!state.container || !centeredLayout || !state.hasContent) {
        if (state.container) state.container.style.display = 'none'
        return
      }

      var pageWidth = window.innerWidth
      var contentWidthValue = Math.max(contentWidth, 25)
      var margin = (pageWidth - contentWidthValue * 16) / 2
      var baseMinSpace = 11 * 16
      var minSpace = tocEnabled ? baseMinSpace + 52 : baseMinSpace + 12

      if (margin >= minSpace) {
        state.container.style.display = 'block'
        state.container.classList.add('fixed-position')
        var leftPosition = tocEnabled ? margin - 176 - 40 : margin - 176
        state.container.style.left = leftPosition + 'px'
      } else {
        state.container.style.display = 'none'
        state.container.classList.remove('fixed-position')
        state.container.style.left = ''
      }
    }

    function handleClick(e) {
      var link = e.target.closest('.toc-link')
      if (!link) return
      e.preventDefault()

      if (link.classList.contains('toc-title')) {
        window.scrollTo({ top: 0, behavior: 'smooth' })
        history.pushState(null, null, '#')
      } else {
        var href = link.getAttribute('href')
        if (href && href.startsWith('#')) {
          var target = document.getElementById(href.substring(1))
          if (target) {
            var rect = target.getBoundingClientRect()
            var scrollTop =
              window.pageYOffset || document.documentElement.scrollTop
            var offset = rect.top + scrollTop - activeOffset
            window.scrollTo({ top: offset, behavior: 'smooth' })
            history.pushState(null, null, href)
          }
        }
      }
    }

    function setActive(nextActiveId) {
      var nextActiveLink =
        nextActiveId && state.headingMap.has(nextActiveId)
          ? state.headingMap.get(nextActiveId)
          : state.titleLink

      if (
        state.activeId === nextActiveId &&
        state.activeLink === nextActiveLink
      ) {
        return
      }

      if (state.activeLink) state.activeLink.classList.remove('active')
      if (nextActiveLink) nextActiveLink.classList.add('active')

      state.activeId = nextActiveId
      state.activeLink = nextActiveLink
    }

    function setupHeadingObserver() {
      if (state.headingObserver) state.headingObserver.disconnect()

      if (!state.headingList.length) {
        setActive(null)
        return
      }

      state.headingObserver = new IntersectionObserver(refreshActiveHeading, {
        rootMargin: '-' + activeOffset + 'px 0px -65% 0px',
        threshold: 0,
      })

      state.headingList.forEach(function (heading) {
        state.headingObserver.observe(heading)
      })
    }

    function refreshActiveHeading() {
      if (!state.headingList.length) {
        setActive(null)
        return
      }

      if (
        window.pageYOffset < 16 ||
        state.headingList[0].getBoundingClientRect().top > activeOffset
      ) {
        setActive(null)
        return
      }

      for (var i = state.headingList.length - 1; i >= 0; i--) {
        if (state.headingList[i].getBoundingClientRect().top <= activeOffset) {
          setActive(state.headingList[i].id)
          break
        }
      }
    }

    function init(retryCount) {
      retryCount = retryCount || 0
      var maxRetries = 5

      if (initElements()) {
        checkContent()
        adjustPosition()
        setupHeadingObserver()

        if (state.container) {
          state.container.addEventListener('click', handleClick)
        }

        refreshActiveHeading()
      } else if (retryCount < maxRetries) {
        setTimeout(function () {
          init(retryCount + 1)
        }, 100)
      }
    }

    function handleResize() {
      if (state.resizeTimeout) cancelAnimationFrame(state.resizeTimeout)
      state.resizeTimeout = requestAnimationFrame(function () {
        adjustPosition()
        refreshActiveHeading()
      })
    }

    function cleanup() {
      if (state.container) {
        state.container.removeEventListener('click', handleClick)
      }

      if (state.headingObserver) {
        state.headingObserver.disconnect()
        state.headingObserver = null
      }

      if (state.resizeTimeout) {
        cancelAnimationFrame(state.resizeTimeout)
        state.resizeTimeout = null
      }

      if (state.resetTimeout) {
        cancelAnimationFrame(state.resetTimeout)
        state.resetTimeout = null
      }

      Object.assign(state, {
        container: null,
        linkList: [],
        headingList: [],
        titleLink: null,
        headingMap: new Map(),
        activeLink: null,
        activeId: null,
        hasContent: false,
      })
    }

    function reset() {
      state.resetTimeout = null
      cleanup()
      init()
    }

    function scheduleReset() {
      if (state.resetTimeout) cancelAnimationFrame(state.resetTimeout)
      state.resetTimeout = requestAnimationFrame(reset)
    }

    function destroy() {
      cleanup()
      document.removeEventListener('astro:page-load', scheduleReset)
      document.removeEventListener('astro:after-swap', scheduleReset)
      window.removeEventListener('resize', handleResize)
      if (window.__tocController?.destroy === destroy) {
        window.__tocController = null
      }
    }

    document.addEventListener('astro:page-load', scheduleReset)
    document.addEventListener('astro:after-swap', scheduleReset)
    window.addEventListener('resize', handleResize)

    window.__tocController = { destroy: destroy }
    init()
  })()
</script>

<style is:inline>
  .toc-container {
    width: 12rem;
    position: relative;
    left: -0.175em;
    opacity: 0;
    transition: opacity 0.2s ease-out;
    display: none;
  }

  .toc-container.fixed-position {
    opacity: 1;
    position: fixed;
    top: 12rem;
    margin-top: 0;
    padding-left: 1rem;
    z-index: 10;
    left: auto;
  }

  .toc-nav {
    font-family: var(--sans);
  }

  .toc-list,
  .toc-list li,
  .toc-item {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  article .toc-container .toc-list {
    margin-left: 0 !important;
    padding-left: 0 !important;
  }

  article .toc-container .toc-list li {
    margin: 0 !important;
    padding: 0 !important;
  }

  .toc-item::before,
  .toc-item::marker {
    display: none;
  }

  .toc-link {
    display: block;
    color: transparent;
    text-decoration: none;
    position: relative;
    padding-left: 0;
    height: 1.125rem;
    width: 100%;
    min-height: 1rem;
    font-size: 0;
    line-height: 1.125rem;
    text-indent: 2rem;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    transition:
      color 0.2s ease-out,
      font-size 0.2s ease-out,
      text-indent 0.2s ease-out;
    cursor: pointer;
  }

  .toc-link::after {
    content: attr(data-text);
    position: absolute;
    left: -0.5rem;
    top: 0;
    font-family: var(--sans);
    font-size: 0.8125rem;
    letter-spacing: -0.02em;
    line-height: 1.125rem;
    color: var(--text-primary);
    opacity: 0;
    transition:
      opacity 0.2s ease-out,
      left 0.2s ease-out;
    pointer-events: none;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    max-width: 100%;
  }

  .toc-link:hover::after {
    opacity: 1;
    left: -0.75rem;
  }

  .toc-level-0 .toc-link:hover::after {
    opacity: 0;
  }

  .toc-level-1 .toc-link:hover::before,
  .toc-level-2 .toc-link:hover::before,
  .toc-level-3 .toc-link:hover::before {
    width: 0.75rem;
    transition: width 0.1s ease-out;
  }

  .toc-link.active {
    color: var(--text-primary);
  }

  .toc-level-0 .toc-link::before,
  .toc-level-1 .toc-link::before,
  .toc-level-2 .toc-link::before,
  .toc-level-3 .toc-link::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 1.75rem;
    height: 1px;
    background-color: var(--text-tertiary);
    transform: translateY(-50%);
    opacity: 0.4;
    transition: all 0.1s ease-out;
  }

  .toc-link:hover::before,
  .toc-link.active::before {
    opacity: 0.8;
    background-color: var(--text-primary);
  }

  @media (max-width: 768px) {
    .toc-container {
      display: none !important;
    }
  }
</style>
