---
import EmailLink from '@/components/ui/EmailLink.astro'
import config from '@/constants/config'

const today = new Date()
---

<footer
  class="text-[length:var(--font-size-s)] font-light leading-[1.75] mt-16 opacity-75"
  style="color: var(--text-secondary);"
>
  <div class="flex justify-between items-center flex-row flex-nowrap w-full">
    <div class="whitespace-nowrap">
      <span class="date opacity-100">&copy; {today.getFullYear()}</span>
      {config.author.name}
    </div>
    <div class="flex gap-4 whitespace-nowrap">
      {
        config.footer.navLinks.map((link) =>
          link.text === 'email' ? (
            <EmailLink text={link.text} className="footer-link" />
          ) : (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="footer-link"
            >
              {link.text}
            </a>
          )
        )
      }
    </div>
  </div>
</footer>

<style>
  @reference "../../styles/global.css";

  footer a,
  footer :global(.footer-link) {
    @apply no-underline transition-colors duration-200 ease-out;
    color: var(--text-secondary);
  }

  footer a:hover,
  footer :global(.footer-link:hover) {
    @apply opacity-100;
    color: var(--text-primary);
  }
</style>
