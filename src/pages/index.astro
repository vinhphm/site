---
import { getCollection } from 'astro:content'
import About from '@/components/widgets/About.astro'
import WritingList from '@/components/widgets/WritingList.astro'
import StructuredData from '@/components/ui/StructuredData.astro'
import config from '@/config'
import Layout from '@/layouts/Layout.astro'
import { sortWritingsByDate } from '@/utils/writing'

const pageUrl = new URL(Astro.url.pathname, Astro.site)

const writings = await getCollection('writings')
const sortedWritings = sortWritingsByDate(writings)

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: config.title,
  alternateName: ['VINH / dev'],
  url: pageUrl,
}
---

<Layout description={config.description}>
  <StructuredData data={structuredData} slot="structured-data" />
  <About />
  <main>
    <WritingList writings={sortedWritings} />
  </main>
</Layout>
