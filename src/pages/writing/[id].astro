---
import type { CollectionEntry } from 'astro:content'
import { getCollection, render } from 'astro:content'
import StructuredData from '@/components/ui/StructuredData.astro'
import WritingLayout from '@/layouts/WritingLayout.astro'
import { createWritingStructuredData } from '@/utils/writing'
import getReadingTime from 'reading-time'

export async function getStaticPaths() {
  const writings = await getCollection('writings')
  return writings.map((entry) => ({
    params: { id: entry.id },
    props: entry,
  }))
}

type Props = CollectionEntry<'writings'>

const writing = Astro.props
const { Content, headings } = await render(writing)

// Build TOC from render headings (depth ≤ 3, skip first h1).
// Strip leading '#' from text because our autolink anchor prepends '#' to each heading.
const toc = headings
  .filter((h) => h.depth >= 2 && h.depth <= 3)
  .map((h) => ({
    level: h.depth,
    text: h.text.replace(/^#\s*/, ''),
    id: h.slug,
  }))

// Compute reading time from raw content body
const rt = getReadingTime(writing.body ?? '')
const readingTime = `${Math.max(1, Math.round(rt.minutes))}min`

const structuredData = createWritingStructuredData(writing)
---

<WritingLayout writing={writing} toc={toc} readingTime={readingTime}>
  <StructuredData data={structuredData} slot="structured-data" />
  <Content />
</WritingLayout>
