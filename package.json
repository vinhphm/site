    "format": "oxfmt --no-error-on-unmatched-pattern . && prettier --write \"**/*.astro\"",
    "format:check": "oxfmt --check . && prettier --check \"**/*.astro\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/markdown-satteri": "^0.2.1",
    "@astrojs/mdx": "6.0.1",
    "@astrojs/rss": "4.0.18",
    "@astrojs/sitemap": "3.7.3",
    "@expressive-code/plugin-collapsible-sections": "^0.42.0",
    "@expressive-code/plugin-line-numbers": "^0.42.0",
    "astro": "6.4.2",
    "astro-expressive-code": "^0.42.0",
    "mdast-util-to-string": "^4.0.0",
    "node-html-parser": "^7.1.0",
    "reading-time": "^1.5.0",
    "sharp": "^0.34.5",
    "unplugin-icons": "^23.0.1"
