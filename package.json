    "@tailwindcss/vite": "4.3.0",
    "@types/prompts": "^2.4.9",
    "bumpp": "^11.1.0",
    "esno": "^4.8.0",
    "husky": "^9.1.7",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.67.0",
    "picocolors": "^1.1.1",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prompts": "^2.4.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "4.3.0",
    "terser": "^5.48.0",
    "typescript": "^6.0.3"
