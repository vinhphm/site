{
  "name": "vinh-dev",
  "version": "3.0.1",
  "type": "module",
  "scripts": {
    "dev": "esno scripts/fetch-link-metadata.ts && astro dev",
    "compress": "esno scripts/img-compress-staged.ts",
    "start": "astro dev",
